SaveToHomeBtn.MouseButton1Click:Connect(function()
    local code = ExecutorCodeInput.Text
    if code:gsub("%s", "") == "" then return end

    local firstLine = code:match("^[^
]*") or "Untitled"
    firstLine = firstLine:gsub("^%-%-%s*", ""):gsub("^%s*(.-)%s*$", "%1")
    if firstLine == "" then firstLine = "Untitled Script" end
    if firstLine:len() > 30 then firstLine = firstLine:sub(1, 30) .. "..." end

    table.insert(SavedScripts, {
        name = firstLine,
        code = code
    })

    local originalText = SaveToHomeBtn.Text
    SaveToHomeBtn.Text = "Saved!"
    task.delay(1.5, function()
        SaveToHomeBtn.Text = originalText
    end)

    RefreshSavedScripts()
end)

