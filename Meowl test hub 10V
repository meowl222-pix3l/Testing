            TextColor3 = Color3.fromRGB(255, 255, 255),
            Parent = SettingRow,
        })
        RoundCorners(ToggleBtn, 13)

        ToggleBtn.MouseButton1Click:Connect(function()
            setting.Value = not setting.Value
            ToggleBtn.BackgroundColor3 = setting.Value and CurrentTheme.Success or CurrentTheme.Error
            ToggleBtn.Text = setting.Value and "ON" or "OFF"
            PlaySound("6780919758", 0.15)

            if setting.Name == "Sound Effects" then Config.SoundEnabled = setting.Value end
            if setting.Name == "Show FPS" then Config.ShowFPS = setting.Value end
            if setting.Name == "Show Ping" then Config.ShowPing = setting.Value end
            if setting.Name == "Show Memory" then Config.ShowMemory = setting.Value end
            if setting.Name == "Floating Cat" then Config.FloatingCatEnabled = setting.Value end
            if setting.Name == "RGB Mode" then Config.RGBMode = setting.Value end
        end)

    elseif setting.Type == "dropdown" then
        local DropdownBtn = Create("TextButton", {
            BackgroundColor3 = CurrentTheme.Tertiary,
            Size = UDim2.new(0, 120, 0, 26),
            Position = UDim2.new(1, -135, 0.5, -13),
            Font = Enum.Font.Gotham,
            Text = Config.Theme,
            TextSize = 11,
            TextColor3 = CurrentTheme.TextPrimary,
            Parent = SettingRow,
        })
        RoundCorners(DropdownBtn, 6)

        DropdownBtn.MouseButton1Click:Connect(function()
            local currentIdx = 1
            for idx, opt in ipairs(setting.Options) do
                if opt == Config.Theme then currentIdx = idx break end
            end
            local nextIdx = currentIdx % #setting.Options + 1
            Config.Theme = setting.Options[nextIdx]
            DropdownBtn.Text = Config.Theme
            CurrentTheme = GetCurrentTheme()
            Notify("Theme", "Theme changed to " .. Config.Theme, "success")
        end)

    elseif setting.Type == "slider" then
        local SliderBox = Create("TextBox", {
            BackgroundColor3 = CurrentTheme.Tertiary,
            Size = UDim2.new(0, 60, 0, 26),
            Position = UDim2.new(1, -75, 0.5, -13),
