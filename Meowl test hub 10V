local function UpdateScriptGrid()
    for _, child in ipairs(ScriptGrid:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end
    ScriptCards = {}

    local filtered = {}
    for _, script in ipairs(ScriptDatabase) do
        if CurrentFilter == "All" or script.Category == CurrentFilter then
            table.insert(filtered, script)
        end
    end

    for i, script in ipairs(filtered) do
        local card = CreateScriptCard(script, i)
        table.insert(ScriptCards, card)
    end

    ScriptGrid.CanvasSize = UDim2.new(0, 0, 0, math.ceil(#filtered / 3) * 130 + 20)
end

UpdateScriptGrid()

