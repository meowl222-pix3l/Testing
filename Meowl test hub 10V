-- Page Switching
function MeowlHub:SwitchPage(pageName)
    if not self.Pages[pageName] then return end

    -- Hide current page
    if self.Pages[self.CurrentPage] then
        self.Pages[self.CurrentPage].Visible = false
    end

    -- Update nav button states
    for name, navData in pairs(self.NavButtons) do
        if name == pageName then
            Utility:Tween(navData.button, {BackgroundTransparency = 0.85}, 0.2)
            Utility:Tween(navData.text, {TextColor3 = Config.AccentColor}, 0.2)
        else
            Utility:Tween(navData.button, {BackgroundTransparency = 1}, 0.2)
            Utility:Tween(navData.text, {TextColor3 = CurrentTheme.TextSecondary}, 0.2)
        end
    end

    -- Show new page
    self.CurrentPage = pageName
    self.Pages[pageName].Visible = true

    -- Update breadcrumb
    local pageNames = {
        Dashboard = "Dashboard",
        Scripts = "Scripts",
        HubBrowser = "Hub Browser",
        GameBrowser = "Game Browser",
        PlayerCenter = "Player Center",
        AvatarCenter = "Avatar Center",
        AnimationCenter = "Animation Center",
        MusicCenter = "Music Center",
        AICenter = "AI Center",
        CloudCenter = "Cloud Center",
        Premium = "Premium",
        Settings = "Settings",
    }
    self.BreadcrumbText.Text = "Meowl Hub / " .. (pageNames[pageName] or pageName)
end

-- Theme Toggle
function MeowlHub:ToggleTheme()
    local themeNames = {"Dark", "Light", "Midnight", "Ocean", "Purple", "Green", "Red", "Gold", "Neon"}
    local currentIndex = table.find(themeNames, Config.Theme) or 1
    local nextIndex = currentIndex % #themeNames + 1
    Config.Theme = themeNames[nextIndex]
    CurrentTheme = Themes[Config.Theme]

    NotificationSystem:Show("Theme Changed", "Switched to " .. Config.Theme .. " theme!", "success")
    -- Note: In a full implementation, you would recursively update all UI elements here
end

-- Clock System
function MeowlHub:StartClock()
    task.spawn(function()
        while self.ClockLabel and self.ClockLabel.Parent do
            local now = os.date("*t")
            local hour = string.format("%02d", now.hour)
            local minute = string.format("%02d", now.min)
            self.ClockLabel.Text = hour .. ":" .. minute

            local days = {"Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"}
            local months = {"January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"}
            self.DateLabel.Text = days[now.wday] .. ", " .. months[now.month] .. " " .. now.day .. ", " .. now.year

            task.wait(1)
        end
    end)
end

-- Performance Monitor
function MeowlHub:StartPerformanceMonitor()
    task.spawn(function()
        local fps = 0
        local lastUpdate = tick()

        RunService.RenderStepped:Connect(function()
            fps = math.floor(1 / (tick() - lastUpdate))
            lastUpdate = tick()
        end)

        -- Create performance display
        local perfDisplay = Utility:Create("Frame", {
            Size = UDim2.new(0, 200, 0, 30),
            Position = UDim2.new(0, 260, 0, 65),
            BackgroundColor3 = Color3.fromRGB(0, 0, 0),
