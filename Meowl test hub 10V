-- ============================================================
local NotificationQueue = {}
local NotificationActive = false

local function Notify(title, message, notifType)
    notifType = notifType or "info"
    local colors = {
        success = CurrentTheme.Success,
        error = CurrentTheme.Error,
        warning = CurrentTheme.Warning,
        info = CurrentTheme.Info,
    }
    local icons = {
        success = "✓",
        error = "✕",
        warning = "!",
        info = "i",
    }

    table.insert(NotificationQueue, {title = title, message = message, notifType = notifType})

    if NotificationActive then return end
    NotificationActive = true

    local notifData = table.remove(NotificationQueue, 1)

    local NotifFrame = Create("Frame", {
        BackgroundColor3 = CurrentTheme.Secondary,
        BackgroundTransparency = 0.1,
        Size = UDim2.new(0, 280, 0, 70),
        Position = UDim2.new(1, 20, 0.85, 0),
        BorderSizePixel = 0,
        Parent = MeowlHub,
    })
    RoundCorners(NotifFrame, 12)
    AddShadow(NotifFrame, 0.3)
    AddStroke(NotifFrame, colors[notifData.notifType], 2)

    local NotifIcon = Create("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 30, 0, 30),
        Position = UDim2.new(0, 12, 0, 10),
        Font = Enum.Font.GothamBold,
        Text = icons[notifData.notifType],
        TextSize = 18,
        TextColor3 = colors[notifData.notifType],
        Parent = NotifFrame,
    })

    local NotifTitle = Create("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -55, 0, 20),
        Position = UDim2.new(0, 45, 0, 8),
        Font = Enum.Font.GothamBold,
        Text = notifData.title,
        TextSize = 14,
        TextColor3 = CurrentTheme.TextPrimary,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = NotifFrame,
    })

    local NotifMessage = Create("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -20, 0, 30),
        Position = UDim2.new(0, 12, 0, 32),
        Font = Enum.Font.Gotham,
        Text = notifData.message,
        TextSize = 12,
        TextColor3 = CurrentTheme.TextSecondary,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        Parent = NotifFrame,
    })

    local ProgressBar = Create("Frame", {
        BackgroundColor3 = colors[notifData.notifType],
        Size = UDim2.new(1, 0, 0, 3),
        Position = UDim2.new(0, 0, 1, -3),
        BorderSizePixel = 0,
        Parent = NotifFrame,
    })

    Tween(NotifFrame, {Position = UDim2.new(1, -300, 0.85, 0)}, 0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    Tween(ProgressBar, {Size = UDim2.new(0, 0, 0, 3)}, 3, Enum.EasingStyle.Linear, Enum.EasingDirection.In, function()
        Tween(NotifFrame, {Position = UDim2.new(1, 20, 0.85, 0)}, 0.4, nil, nil, function()
            NotifFrame:Destroy()
            NotificationActive = false
            if #NotificationQueue > 0 then
                task.wait(0.1)
                Notify(NotificationQueue[1].title, NotificationQueue[1].message, NotificationQueue[1].notifType)
            end
        end)
    end)
end

