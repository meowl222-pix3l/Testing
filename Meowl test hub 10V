local function showPage(name)
\tfor n, p in pairs(pages) do
\t\tp.Visible = n == name
\tend
\tstate.lastPage = name
end

for name, btn in pairs(navs) do
\tbtn.MouseEnter:Connect(function()
\t\ttween(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(32, 32, 42)})
\tend)
\tbtn.MouseLeave:Connect(function()
\t\tif state.lastPage ~= name then
\t\t\ttween(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(22, 22, 28)})
\t\tend
\tend)
\tbtn.MouseButton1Click:Connect(function()
\t\tshowPage(name)
\t\tfor n, b in pairs(navs) do
\t\t\ttween(b, TweenInfo.new(0.15), {BackgroundColor3 = (n == name) and Color3.fromRGB(42, 36, 70) or Color3.fromRGB(22, 22, 28)})
\t\tend
\tend)
end

