local function SwitchTab(tabId)
    CurrentTab = tabId
    for id, content in pairs(TabContents) do
        content.Visible = (id == tabId)
    end
    for _, btn in pairs(TabButtons) do
        if btn.Id == tabId then
            Tween(btn.Button, {BackgroundColor3 = CONFIG.AccentColor}, 0.2)
            btn.Button.TextColor3 = CONFIG.TextColor
        else
            Tween(btn.Button, {BackgroundColor3 = Color3.fromRGB(28, 28, 35)}, 0.2)
            btn.Button.TextColor3 = CONFIG.SubTextColor
        end
    end
end

for i, tab in ipairs(Tabs) do
    local btn = Create("TextButton", {
        Name = tab.id .. "Btn",
        Parent = Sidebar,
        Size = UDim2.new(1, -16, 0, 42),
        Position = UDim2.new(0, 8, 0, 15 + (i - 1) * 50),
        BackgroundColor3 = (i == 1) and CONFIG.AccentColor or Color3.fromRGB(28, 28, 35),
        BorderSizePixel = 0,
        Text = tab.name,
        TextColor3 = (i == 1) and CONFIG.TextColor or CONFIG.SubTextColor,
        TextSize = 14,
        Font = CONFIG.FontBold,
        AutoButtonColor = false,
    })

    AddUICorner(btn, 8)
    table.insert(TabButtons, {Button = btn, Id = tab.id})

    btn.MouseButton1Click:Connect(function()
        SwitchTab(tab.id)
    end)

    btn.MouseEnter:Connect(function()
        if CurrentTab ~= tab.id then
            Tween(btn, {BackgroundColor3 = Color3.fromRGB(40, 40, 50)}, 0.2)
        end
    end)

    btn.MouseLeave:Connect(function()
        if CurrentTab ~= tab.id then
            Tween(btn, {BackgroundColor3 = Color3.fromRGB(28, 28, 35)}, 0.2)
        end
    end)
end

