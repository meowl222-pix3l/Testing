            BackgroundColor3 = (item.type == "danger") and CONFIG.ErrorColor or CONFIG.AccentColor,
            BorderSizePixel = 0,
            Text = (item.type == "danger") and "Clear" or "Apply",
            TextColor3 = CONFIG.TextColor,
            TextSize = 12,
            Font = CONFIG.FontBold,
            AutoButtonColor = false,
        })
        AddUICorner(actionBtn, 6)

        actionBtn.MouseButton1Click:Connect(function()
            item.action()
            actionBtn.Text = "Done"
            task.delay(1, function()
                actionBtn.Text = (item.type == "danger") and "Clear" or "Apply"
            end)
        end)
    end
end

-- UNLOCK LOGIC
local function UnlockExecutor()
    Tween(KeyFrame, {Size = UDim2.new(0, 440, 0, 0)}, 0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In)
    Tween(KeyFrame, {Position = UDim2.new(0.5, -220, 0.5, 0)}, 0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In)
    task.delay(0.4, function()
        KeyFrame.Visible = false
        MainFrame.Visible = true
        MainFrame.Size = UDim2.new(0, 800, 0, 0)
        MainFrame.Position = UDim2.new(0.5, -400, 0.5, 0)
        Tween(MainFrame, {Size = UDim2.new(0, 800, 0, 550)}, 0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        Tween(MainFrame, {Position = UDim2.new(0.5, -400, 0.5, -275)}, 0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    end)
end

UnlockBtn.MouseButton1Click:Connect(function()
    local input = KeyInput.Text:gsub("^%s*(.-)%s*$", "%1")
    if input == "" then
        StatusLabel.Text = "Please enter a key"
        return
    end
    if input == CONFIG.ValidKey then
        StatusLabel.TextColor3 = CONFIG.SuccessColor
        StatusLabel.Text = "Access granted! Unlocking..."
        task.delay(0.5, UnlockExecutor)
    else
        StatusLabel.TextColor3 = CONFIG.ErrorColor
        StatusLabel.Text = "Invalid key. Copy the key above and paste it."
        KeyInput.Text = ""
    end
end)

KeyInput.FocusLost:Connect(function(enterPressed)
    if enterPressed then UnlockBtn.MouseButton1Click:Fire() end
end)

-- DRAGGABLE & TOGGLE
local function MakeDraggable(frame, handle)
    handle = handle or frame
    local dragging = false
    local dragStart, startPos

    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

MakeDraggable(KeyFrame)
MakeDraggable(MainFrame, TopBar)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == Enum.KeyCode.RightShift then
        if MainFrame.Visible then
            MainFrame.Visible = false
        elseif KeyFrame.Visible then
            KeyFrame.Visible = false
        else
            KeyFrame.Visible = true
            KeyFrame.Size = UDim2.new(0, 440, 0, 340)
            KeyFrame.Position = UDim2.new(0.5, -220, 0.5, -170)
        end
    end
end)

