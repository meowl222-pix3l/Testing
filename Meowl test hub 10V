-- Loading Animation
local loadingSteps = {
    {Text = "Loading assets...", Progress = 0.1},
    {Text = "Connecting to server...", Progress = 0.25},
    {Text = "Fetching scripts...", Progress = 0.4},
    {Text = "Building UI...", Progress = 0.6},
    {Text = "Applying theme...", Progress = 0.75},
    {Text = "Finalizing...", Progress = 0.9},
    {Text = "Ready!", Progress = 1},
}

local function RunLoadingAnimation()
    for i, step in ipairs(loadingSteps) do
        task.wait(0.3)
        LoadingStatus.Text = step.Text
        Tween(ProgressBar, {Size = UDim2.new(step.Progress, 0, 1, 0)}, 0.3)
    end
    task.wait(0.5)
    Tween(LoadingScreen, {BackgroundTransparency = 1}, 0.5, nil, nil, function()
        LoadingScreen.Visible = false
        MeowlData.Stats.TotalOpens = MeowlData.Stats.TotalOpens + 1
        Notify("Welcome", "Meowl Hub V10 loaded successfully!", "success")
    end)
    for _, child in ipairs(LoadingScreen:GetDescendants()) do
        if child:IsA("GuiObject") then
            Tween(child, {TextTransparency = 1, BackgroundTransparency = 1, ImageTransparency = 1}, 0.5)
        end
    end
end

