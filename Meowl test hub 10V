-- ==========================================
-- NAVIGATION SETUP
-- ==========================================
local activeBtnTab = nil

local function switchPage(name)
    if Pages[name] then
        for _, p in pairs(Pages) do
            p.Visible = false
        end
        CurrentPage = Pages[name]
        CurrentPage.Visible = true
        CurrentPage.Position = UDim2.new(0.05, 0, 0, 0)
        tween(CurrentPage, 0.35, {Position = UDim2.new(0, 0, 0, 0)}, Enum.EasingStyle.Quart)
    end
end

