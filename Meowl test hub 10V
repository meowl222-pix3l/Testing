local dragging = false
local dragStart, startPos

top.InputBegan:Connect(function(input)
\tif input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
\t\tdragging = true
\t\tdragStart = input.Position
\t\tstartPos = main.Position
\t\tinput.Changed:Connect(function()
\t\t\tif input.UserInputState == Enum.UserInputState.End then
\t\t\t\tdragging = false
\t\t\tend
\t\tend)
\tend
end)

top.InputChanged:Connect(function(input)
\tif input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
\t\tlocal connection
\t\tconnection = UserInputService.InputChanged:Connect(function(move)
\t\t\tif dragging and (move.UserInputType == Enum.UserInputType.MouseMovement or move.UserInputType == Enum.UserInputType.Touch) then
\t\t\t\tlocal delta = move.Position - dragStart
\t\t\t\tmain.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
\t\t\tend
\t\tend)
\t\ttask.defer(function()
\t\t\tif connection then connection:Disconnect() end
\t\tend)
\tend
end)

