--  PAGE UPDATE FUNCTION
-- ============================================================
local function UpdatePage(pageName)
    Breadcrumb.Text = "Home  >  " .. pageName

    for _, child in ipairs(PageContainer:GetChildren()) do
        if child:IsA("ScrollingFrame") or child:IsA("Frame") then
            child.Visible = false
        end
    end

    if PageContents[pageName] then
        PageContents[pageName].Visible = true
        Tween(PageContents[pageName], {Position = UDim2.new(0, 0, 0, 0)}, 0.3)
    end

    MeowlData.Stats.FavoritePage = pageName
end

