            Text = tostring(setting.Value),
            TextSize = 11,
            TextColor3 = CurrentTheme.TextPrimary,
            Parent = SettingRow,
        })
        RoundCorners(SliderBox, 6)

        SliderBox.FocusLost:Connect(function()
            local val = tonumber(SliderBox.Text)
            if val then
                val = math.clamp(val, setting.Min, setting.Max)
                setting.Value = val
                SliderBox.Text = tostring(val)
                if setting.Name == "UI Scale" then
                    MainUI.Size = UDim2.new(0, 900 * val, 0, 580 * val)
                end
            end
        end)
    end
end

