function AddOutput(text, isError)
    local timestamp = os.date("%H:%M:%S")
    local prefix = isError and "[ERROR]" or "[INFO]"
    OutputText.Text = OutputText.Text .. string.format("[%s] %s %s
", timestamp, prefix, text)
    task.delay(0.1, function()
        OutputScroll.CanvasPosition = Vector2.new(0, OutputScroll.AbsoluteCanvasSize.Y)
    end)
end

ExecBtn.MouseButton1Click:Connect(function()
    local code = ExecutorCodeInput.Text
    if code:gsub("%s", "") == "" then return end

    AddOutput("Executing code...", false)

    local env = setmetatable({
        print = function(...)
            local args = {...}
            local str = ""
            for i, v in ipairs(args) do str = str .. tostring(v) .. (i < #args and " " or "") end
            AddOutput(str, false)
        end,
        warn = function(...)
            local args = {...}
            local str = ""
            for i, v in ipairs(args) do str = str .. tostring(v) .. (i < #args and " " or "") end
            AddOutput("WARN: " .. str, true)
        end,
        game = game, workspace = workspace, script = script,
        Players = Players, TweenService = TweenService,
        _G = _G, pairs = pairs, ipairs = ipairs,
        next = next, tonumber = tonumber, tostring = tostring,
        type = type, typeof = typeof, unpack = unpack,
        select = select, pcall = pcall, xpcall = xpcall,
        assert = assert, rawget = rawget, rawset = rawset,
        rawequal = rawequal, math = math, string = string,
        table = table, coroutine = coroutine,
        os = {clock = os.clock, date = os.date, difftime = os.difftime, time = os.time},
        Instance = Instance, Vector3 = Vector3, Vector2 = Vector2,
        Color3 = Color3, CFrame = CFrame, UDim = UDim, UDim2 = UDim2,
        Enum = Enum, TweenInfo = TweenInfo, tick = tick, time = time,
        wait = task.wait, spawn = task.spawn, delay = task.delay, task = task,
    }, {__index = _G})

    local func, compileErr = loadstring(code)
    if not func then
        AddOutput("Compilation Error: " .. tostring(compileErr), true)
        return
    end

    setfenv(func, env)
    local success, result = pcall(func)
    if not success then
        AddOutput("Runtime Error: " .. tostring(result), true)
    else
        if result ~= nil then AddOutput("Returned: " .. tostring(result), false) end
        AddOutput("Execution completed!", false)
    end
end)

