local function create(className, props)
\tlocal obj = Instance.new(className)
\tfor k, v in pairs(props or {}) do
\t\tobj[k] = v
\tend
\treturn obj
end

local function tween(obj, info, goal)
\tlocal t = TweenService:Create(obj, info, goal)
\tt:Play()
\treturn t
end

