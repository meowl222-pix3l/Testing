    -- Interactive visual feedbacks
    Btn.MouseEnter:Connect(function()
        if activeBtnTab ~= Btn then
            tween(Btn, 0.2, {BackgroundTransparency = 0.9, BackgroundColor3 = Theme.Accent})
            tween(Label, 0.2, {TextColor3 = Theme.Text})
        end
    end)
    Btn.MouseLeave:Connect(function()
        if activeBtnTab ~= Btn then
            tween(Btn, 0.2, {BackgroundTransparency = 1})
            tween(Label, 0.2, {TextColor3 = Theme.DarkText})
        end
    end)

    Btn.MouseButton1Click:Connect(function()
        if activeBtnTab then
            tween(activeBtnTab, 0.2, {BackgroundTransparency = 1})
            activeBtnTab:FindFirstChildOfClass("TextLabel").TextColor3 = Theme.DarkText
        end
        activeBtnTab = Btn
        tween(Btn, 0.2, {BackgroundTransparency = 0.8, BackgroundColor3 = Theme.Accent})
        Label.TextColor3 = Theme.Accent
        switchPage(pageName)
    end)
end

